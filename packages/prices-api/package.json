{
  "name": "@curvefi/prices-api",
  "version": "3.1.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "yarn build:deps && node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && yarn build:js && yarn build:types",
    "build:deps": "yarn workspace @curvefi/primitives build",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build-types.json --emitDeclarationOnly",
    "prepublishOnly": "yarn run build",
    "lint": "eslint --cache --cache-location ../../.cache/eslint/prices-api --cache-strategy content .",
    "lint:fix": "eslint --cache --cache-location ../../.cache/eslint/prices-api --cache-strategy content . --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:endpoints": "vitest run --config vitest.endpoints.config.ts",
    "typecheck": "tsc --noEmit --tsBuildInfoFile ../../.cache/typecheck/packages-prices-api.tsbuildinfo"
  },
  "peerDependencies": {
    "typescript": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "eslint": "*",
    "typescript": "*",
    "vite": "*",
    "vitest": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "JavaScript library for Curve Finance Prices API",
  "homepage": "https://curve.finance",
  "keywords": [
    "curve",
    "finance",
    "defi",
    "prices",
    "crypto",
    "dex",
    "crvusd"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/curvefi/curve-frontend.git",
    "directory": "packages/prices-api"
  },
  "bugs": {
    "url": "https://github.com/curvefi/curve-frontend/issues"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    }
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
