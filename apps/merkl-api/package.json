{
  "name": "merkl-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "lint": "eslint --cache --cache-location ../../.cache/eslint/merkl-api --cache-strategy content .",
    "lint:fix": "eslint --cache --cache-location ../../.cache/eslint/merkl-api --cache-strategy content . --fix",
    "typecheck": "tsc --tsBuildInfoFile ../../.cache/typecheck/apps-merkl-api.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "5.8.5"
  },
  "devDependencies": {
    "@types/node": "*",
    "eslint": "*",
    "tsx": "4.22.4",
    "typescript": "*",
    "vitest": "*"
  }
}
