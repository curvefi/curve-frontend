{
  "name": "tests",
  "version": "0.1.0",
  "description": "Curve DApp tests",
  "license": "MIT",
  "main": "index.js",
  "installConfig": {
    "hoistingLimits": "dependencies"
  },
  "scripts": {
    "lint": "eslint --cache --cache-location ../../.cache/eslint/tests --cache-strategy content .",
    "lint:fix": "eslint --cache --cache-location ../../.cache/eslint/tests --cache-strategy content . --fix",
    "typecheck": "tsc --tsBuildInfoFile ../.cache/typecheck/tests.tsbuildinfo",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "vitest:watch": "vitest --watch",
    "cy": "cypress",
    "cy:open:e2e": "cypress open --e2e",
    "cy:run:e2e": "wait-on http://localhost:3000 --timeout 1m && cypress run --e2e",
    "cy:open:component": "cypress open --component",
    "cy:run:component": "cypress run --component --spec 'cypress/component/**/!(*.rpc).cy.{ts,tsx}'",
    "cy:run:rpc": "cypress run --component --spec 'cypress/component/**/*.rpc.cy.{ts,tsx}'",
    "download:artifacts": "node --experimental-strip-types scripts/download-artifacts.ts"
  },
  "devDependencies": {
    "@cypress/react": "9.0.2",
    "@cypress/vite-dev-server": "7.3.1",
    "@types/cypress": "1.1.6",
    "@vitejs/plugin-react": "*",
    "@vitest/ui": "4.1.5",
    "cypress": "15.14.1",
    "eslint": "*",
    "ethers": "*",
    "typescript": "*",
    "vite": "*",
    "vite-plugin-svgr": "*",
    "vitest": "*",
    "wait-on": "9.0.5"
  }
}
